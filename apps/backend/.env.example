NODE_ENV=development
PORT=3000
# PostgreSQL 连接字符串
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://postgres:password@localhost:5432/pulsebuild

# Twilio 账户 SID (从 Twilio 控制台获取)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
# Twilio 认证令牌 (从 Twilio 控制台获取)
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Twilio 发送号码 (用于发送短信的手机号)
TWILIO_FROM_NUMBER=+1234567890

# Google Maps API Key (用于地理位置代理服务)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# 本地文件存储目录 (相对路径或绝对路径)
UPLOAD_DIR=./uploads

# 上传文件访问基础 URL (生产环境需修改为实际域名)
UPLOAD_BASE_URL=http://localhost:3000/uploads

# Better Auth 密钥 (用于加密会话等敏感数据)
BETTER_AUTH_SECRET=your_secret_key_at_least_32_characters
# Better Auth 服务 URL (本地开发使用 localhost，生产环境需修改为实际域名)
BETTER_AUTH_URL=http://localhost:3000